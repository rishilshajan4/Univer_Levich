{
  "name": "@levichco/finsheets",
  "version": "0.1.4",
  "description": "Reusable, fully Levich/FinOpz-branded spreadsheet package wrapping the free (Apache-2.0) Univer engine. Embeddable with one React component: Google-Sheets-style menus & toolbar, rich .xlsx import (styles, merges, number formats, images, multi-sheet) and full-fidelity export, filter/group views, a full function catalog, cross-platform keyboard shortcuts, and Google-style sheet management.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/levichco/FinSheets.git"
  },
  "homepage": "https://github.com/levichco/FinSheets#readme",
  "bugs": {
    "url": "https://github.com/levichco/FinSheets/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "vite",
    "demo:build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm test",
    "release": "npm run verify && npm run build && npm pack",
    "prepublishOnly": "npm run verify && npm run build",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@univerjs/presets": "0.25.0",
    "@univerjs/preset-sheets-core": "0.25.0",
    "@univerjs/preset-sheets-conditional-formatting": "0.25.0",
    "@univerjs/preset-sheets-data-validation": "0.25.0",
    "@univerjs/preset-sheets-drawing": "0.25.0",
    "@univerjs/preset-sheets-filter": "0.25.0",
    "@univerjs/preset-sheets-find-replace": "0.25.0",
    "@univerjs/preset-sheets-hyper-link": "0.25.0",
    "@univerjs/preset-sheets-note": "0.25.0",
    "@univerjs/preset-sheets-sort": "0.25.0",
    "@univerjs/preset-sheets-table": "0.25.0",
    "@untitledui/icons": "^0.0.20",
    "exceljs": "4.4.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
